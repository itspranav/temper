<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
  <edmx:DataServices>
    <Schema Namespace="Temper.dsfReview" xmlns="http://docs.oasis-open.org/odata/ns/edm">

      <!-- StoryEvaluation Entity — Tracks DSF stories through evaluation pipeline -->
      <EntityType Name="StoryEvaluation">
        <Key>
          <PropertyRef Name="Id"/>
        </Key>
        <Property Name="Id" Type="Edm.Guid" Nullable="false"/>
        <Property Name="StoryId" Type="Edm.String" Nullable="false"/>
        <Property Name="Title" Type="Edm.String" Nullable="false"/>
        <Property Name="Author" Type="Edm.String" Nullable="false"/>
        <Property Name="World" Type="Edm.String" Nullable="false"/>
        <Property Name="WorldYear" Type="Edm.Int32" Nullable="false"/>
        <Property Name="StoryURL" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String" Nullable="false" DefaultValue="Fetched"/>
        <Property Name="HasFullContent" Type="Edm.Boolean" Nullable="false" DefaultValue="false"/>
        <Property Name="FScore" Type="Edm.Int32" Nullable="false" DefaultValue="0"/>
        <Property Name="CScore" Type="Edm.Int32" Nullable="false" DefaultValue="0"/>
        <Property Name="WScore" Type="Edm.Int32" Nullable="false" DefaultValue="0"/>
        <Property Name="OScore" Type="Edm.Int32" Nullable="false" DefaultValue="0"/>
        <Property Name="XScore" Type="Edm.Int32" Nullable="false" DefaultValue="0"/>
        <Property Name="ReviewCount" Type="Edm.Int32" Nullable="false" DefaultValue="0"/>
        <Property Name="AcclaimCount" Type="Edm.Int32" Nullable="false" DefaultValue="0"/>
        <Property Name="Notes" Type="Edm.String" Nullable="true"/>
        <Property Name="PullQuote" Type="Edm.String" Nullable="true"/>
        <Property Name="CreatedAt" Type="Edm.DateTimeOffset" Nullable="false"/>
        <Property Name="UpdatedAt" Type="Edm.DateTimeOffset" Nullable="false"/>
      </EntityType>

      <EntityContainer Name="Service">
        <EntitySet Name="StoryEvaluations" EntityType="Temper.dsfReview.StoryEvaluation"/>
      </EntityContainer>

    </Schema>
  </edmx:DataServices>
</edmx:Edmx>
