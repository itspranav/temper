<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
  <edmx:DataServices>
    <Schema Namespace="Temper" xmlns="http://docs.oasis-open.org/odata/ns/edm">

      <EntityType Name="LeadPlan">
        <Key><PropertyRef Name="id"/></Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="test_workflow_id" Type="Edm.String"/>
        <Property Name="review_workflow_id" Type="Edm.String"/>
        <Property Name="deploy_workflow_id" Type="Edm.String"/>
        <Property Name="deploy_url" Type="Edm.String"/>
        <Property Name="reason" Type="Edm.String"/>
      </EntityType>

      <EntityType Name="TestWorkflow">
        <Key><PropertyRef Name="id"/></Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="test_count" Type="Edm.String"/>
        <Property Name="coverage" Type="Edm.String"/>
        <Property Name="failures" Type="Edm.String"/>
        <Property Name="error_log" Type="Edm.String"/>
      </EntityType>

      <EntityType Name="ReviewWorkflow">
        <Key><PropertyRef Name="id"/></Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="reviewer" Type="Edm.String"/>
        <Property Name="comments" Type="Edm.String"/>
        <Property Name="change_requests" Type="Edm.String"/>
        <Property Name="reason" Type="Edm.String"/>
      </EntityType>

      <EntityType Name="DeployWorkflow">
        <Key><PropertyRef Name="id"/></Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="environment" Type="Edm.String"/>
        <Property Name="version" Type="Edm.String"/>
        <Property Name="deploy_url" Type="Edm.String"/>
        <Property Name="reason" Type="Edm.String"/>
      </EntityType>

      <EntityContainer Name="Service">
        <EntitySet Name="LeadPlans" EntityType="Temper.LeadPlan"/>
        <EntitySet Name="TestWorkflows" EntityType="Temper.TestWorkflow"/>
        <EntitySet Name="ReviewWorkflows" EntityType="Temper.ReviewWorkflow"/>
        <EntitySet Name="DeployWorkflows" EntityType="Temper.DeployWorkflow"/>
      </EntityContainer>

    </Schema>
  </edmx:DataServices>
</edmx:Edmx>
