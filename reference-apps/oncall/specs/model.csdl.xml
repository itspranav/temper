<?xml version="1.0" encoding="utf-8"?>
<!--
  Temper Reference On-Call Application

  This CSDL defines an OData v4 data model for the reference on-call
  application. Agents are the on-call responders — they get paged,
  investigate, run remediations, and escalate to more capable agents.
  Humans are the last-resort tier and hold the approval gate for
  destructive remediations.

  Entities: Page, EscalationPolicy, Remediation, Postmortem
-->
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
  <edmx:DataServices>

    <!-- ================================================================== -->
    <!-- Custom Vocabulary: Temper Extensions                                -->
    <!-- ================================================================== -->
    <Schema Namespace="Temper.Vocab" xmlns="http://docs.oasis-open.org/odata/ns/edm">
      <!-- State machine metadata -->
      <Term Name="StateMachine.States" Type="Collection(Edm.String)"
            AppliesTo="EntityType"
            Description="Valid states for this entity's state machine"/>
      <Term Name="StateMachine.InitialState" Type="Edm.String"
            AppliesTo="EntityType"
            Description="The initial state when an entity is created"/>
      <Term Name="StateMachine.ValidFromStates" Type="Collection(Edm.String)"
            AppliesTo="Action"
            Description="States from which this action can be invoked"/>
      <Term Name="StateMachine.TargetState" Type="Edm.String"
            AppliesTo="Action"
            Description="State the entity transitions to after this action"/>

      <!-- Agent hints -->
      <Term Name="Agent.Hint" Type="Edm.String"
            AppliesTo="Action Function EntityType"
            Description="Usage hint for LLM agents"/>
      <Term Name="Agent.CommonPattern" Type="Edm.String"
            AppliesTo="Action Function"
            Description="Common successful trajectory pattern"/>

      <!-- Sharding -->
      <Term Name="ShardKey" Type="Edm.String"
            AppliesTo="EntityType"
            Description="Comma-separated property names used as shard key"/>
    </Schema>

    <!-- ================================================================== -->
    <!-- On-Call Domain Model                                                -->
    <!-- ================================================================== -->
    <Schema Namespace="Temper.OnCall" xmlns="http://docs.oasis-open.org/odata/ns/edm">

      <!-- ============ Enums ============ -->

      <EnumType Name="PageStatus">
        <Member Name="Triggered" Value="0"/>
        <Member Name="Investigating" Value="1"/>
        <Member Name="Escalated" Value="2"/>
        <Member Name="Remediated" Value="3"/>
        <Member Name="Resolved" Value="4"/>
      </EnumType>

      <EnumType Name="EscalationPolicyStatus">
        <Member Name="Idle" Value="0"/>
        <Member Name="Active" Value="1"/>
        <Member Name="Exhausted" Value="2"/>
      </EnumType>

      <EnumType Name="RemediationStatus">
        <Member Name="Proposed" Value="0"/>
        <Member Name="Approved" Value="1"/>
        <Member Name="Executing" Value="2"/>
        <Member Name="Succeeded" Value="3"/>
        <Member Name="Failed" Value="4"/>
        <Member Name="Rejected" Value="5"/>
      </EnumType>

      <EnumType Name="PostmortemStatus">
        <Member Name="Draft" Value="0"/>
        <Member Name="InReview" Value="1"/>
        <Member Name="Approved" Value="2"/>
        <Member Name="Published" Value="3"/>
      </EnumType>

      <!-- ============ Entity Types ============ -->

      <!-- Page: an alert assigned to an on-call agent -->
      <EntityType Name="Page">
        <Key>
          <PropertyRef Name="Id"/>
        </Key>
        <Property Name="Id" Type="Edm.Guid" Nullable="false"/>
        <Property Name="AlertName" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Temper.OnCall.PageStatus" Nullable="false"/>
        <Property Name="Severity" Type="Edm.String" Nullable="false"/>
        <Property Name="AgentId" Type="Edm.String"/>
        <Property Name="EscalationTier" Type="Edm.Int32" DefaultValue="0"/>
        <Property Name="TriggeredAt" Type="Edm.DateTimeOffset" Nullable="false"/>
        <Property Name="ResolvedAt" Type="Edm.DateTimeOffset"/>
        <NavigationProperty Name="Remediations" Type="Collection(Temper.OnCall.Remediation)"/>
        <NavigationProperty Name="Postmortem" Type="Temper.OnCall.Postmortem"/>

        <Annotation Term="Temper.Vocab.StateMachine.States">
          <Collection>
            <String>Triggered</String>
            <String>Investigating</String>
            <String>Escalated</String>
            <String>Remediated</String>
            <String>Resolved</String>
          </Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.InitialState" String="Triggered"/>
        <Annotation Term="Temper.Vocab.ShardKey" String="Id"/>
      </EntityType>

      <!-- EscalationPolicy: defines the agent escalation chain -->
      <EntityType Name="EscalationPolicy">
        <Key>
          <PropertyRef Name="Id"/>
        </Key>
        <Property Name="Id" Type="Edm.Guid" Nullable="false"/>
        <Property Name="Name" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Temper.OnCall.EscalationPolicyStatus" Nullable="false"/>
        <Property Name="CurrentStep" Type="Edm.Int32" DefaultValue="0"/>
        <Property Name="MaxSteps" Type="Edm.Int32" Nullable="false"/>
        <Property Name="CreatedAt" Type="Edm.DateTimeOffset" Nullable="false"/>

        <Annotation Term="Temper.Vocab.StateMachine.States">
          <Collection>
            <String>Idle</String>
            <String>Active</String>
            <String>Exhausted</String>
          </Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.InitialState" String="Idle"/>
        <Annotation Term="Temper.Vocab.ShardKey" String="Id"/>
      </EntityType>

      <!-- Remediation: an action the agent takes to fix the issue -->
      <EntityType Name="Remediation">
        <Key>
          <PropertyRef Name="Id"/>
        </Key>
        <Property Name="Id" Type="Edm.Guid" Nullable="false"/>
        <Property Name="PageId" Type="Edm.Guid" Nullable="false"/>
        <Property Name="Status" Type="Temper.OnCall.RemediationStatus" Nullable="false"/>
        <Property Name="ActionType" Type="Edm.String" Nullable="false"/>
        <Property Name="Description" Type="Edm.String"/>
        <Property Name="Attempts" Type="Edm.Int32" DefaultValue="0"/>
        <Property Name="HumanApproved" Type="Edm.Boolean" DefaultValue="false"/>
        <Property Name="CreatedAt" Type="Edm.DateTimeOffset" Nullable="false"/>
        <NavigationProperty Name="Page" Type="Temper.OnCall.Page" Nullable="false">
          <ReferentialConstraint Property="PageId" ReferencedProperty="Id"/>
        </NavigationProperty>

        <Annotation Term="Temper.Vocab.StateMachine.States">
          <Collection>
            <String>Proposed</String>
            <String>Approved</String>
            <String>Executing</String>
            <String>Succeeded</String>
            <String>Failed</String>
            <String>Rejected</String>
          </Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.InitialState" String="Proposed"/>
        <Annotation Term="Temper.Vocab.ShardKey" String="Id"/>
      </EntityType>

      <!-- Postmortem: agent-drafted incident analysis -->
      <EntityType Name="Postmortem">
        <Key>
          <PropertyRef Name="Id"/>
        </Key>
        <Property Name="Id" Type="Edm.Guid" Nullable="false"/>
        <Property Name="PageId" Type="Edm.Guid" Nullable="false"/>
        <Property Name="Status" Type="Temper.OnCall.PostmortemStatus" Nullable="false"/>
        <Property Name="Title" Type="Edm.String" Nullable="false"/>
        <Property Name="RootCause" Type="Edm.String"/>
        <Property Name="ReviewRounds" Type="Edm.Int32" DefaultValue="0"/>
        <Property Name="CreatedAt" Type="Edm.DateTimeOffset" Nullable="false"/>
        <Property Name="PublishedAt" Type="Edm.DateTimeOffset"/>
        <NavigationProperty Name="Page" Type="Temper.OnCall.Page" Nullable="false">
          <ReferentialConstraint Property="PageId" ReferencedProperty="Id"/>
        </NavigationProperty>

        <Annotation Term="Temper.Vocab.StateMachine.States">
          <Collection>
            <String>Draft</String>
            <String>InReview</String>
            <String>Approved</String>
            <String>Published</String>
          </Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.InitialState" String="Draft"/>
        <Annotation Term="Temper.Vocab.ShardKey" String="Id"/>
      </EntityType>

      <!-- ============ Actions ============ -->

      <!-- Page Actions -->
      <Action Name="AssignAgent" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Page"/>
        <Parameter Name="AgentId" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Temper.OnCall.Page"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Triggered</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.Agent.Hint"
                    String="Assign an on-call agent to handle this page. Must be done before investigation."/>
      </Action>

      <Action Name="StartInvestigation" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Page"/>
        <ReturnType Type="Temper.OnCall.Page"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Triggered</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Investigating"/>
        <Annotation Term="Temper.Vocab.Agent.Hint"
                    String="Begin investigating the alert. Requires an agent to be assigned first."/>
      </Action>

      <Action Name="Escalate" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Page"/>
        <ReturnType Type="Temper.OnCall.Page"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Investigating</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Escalated"/>
        <Annotation Term="Temper.Vocab.Agent.Hint"
                    String="Escalate the page to a higher tier agent. Increments escalation counter."/>
      </Action>

      <Action Name="ReassignAgent" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Page"/>
        <Parameter Name="AgentId" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Temper.OnCall.Page"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Escalated</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Investigating"/>
        <Annotation Term="Temper.Vocab.Agent.Hint"
                    String="Reassign to a more capable agent after escalation."/>
      </Action>

      <Action Name="StartRemediation" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Page"/>
        <ReturnType Type="Temper.OnCall.Page"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Investigating</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Remediated"/>
      </Action>

      <Action Name="Resolve" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Page"/>
        <ReturnType Type="Temper.OnCall.Page"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Remediated</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Resolved"/>
      </Action>

      <Action Name="AutoResolve" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Page"/>
        <ReturnType Type="Temper.OnCall.Page"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Triggered</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Resolved"/>
        <Annotation Term="Temper.Vocab.Agent.Hint"
                    String="Source alert cleared — page auto-resolves without investigation."/>
      </Action>

      <Action Name="Timeout" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Page"/>
        <ReturnType Type="Temper.OnCall.Page"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Investigating</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Escalated"/>
      </Action>

      <!-- EscalationPolicy Actions -->
      <Action Name="Activate" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.EscalationPolicy"/>
        <ReturnType Type="Temper.OnCall.EscalationPolicy"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Idle</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Active"/>
      </Action>

      <Action Name="StepUp" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.EscalationPolicy"/>
        <ReturnType Type="Temper.OnCall.EscalationPolicy"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Active</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.Agent.Hint"
                    String="Move to the next escalation tier. Requires escalation to not be snoozed."/>
      </Action>

      <Action Name="Snooze" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.EscalationPolicy"/>
        <ReturnType Type="Temper.OnCall.EscalationPolicy"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Active</String></Collection>
        </Annotation>
      </Action>

      <Action Name="Unsnooze" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.EscalationPolicy"/>
        <ReturnType Type="Temper.OnCall.EscalationPolicy"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Active</String></Collection>
        </Annotation>
      </Action>

      <Action Name="Exhaust" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.EscalationPolicy"/>
        <ReturnType Type="Temper.OnCall.EscalationPolicy"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Active</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Exhausted"/>
      </Action>

      <Action Name="Reset" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.EscalationPolicy"/>
        <ReturnType Type="Temper.OnCall.EscalationPolicy"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Exhausted</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Idle"/>
      </Action>

      <!-- Remediation Actions -->
      <Action Name="Approve" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Remediation"/>
        <Parameter Name="ApproverId" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Temper.OnCall.Remediation"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Proposed</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Approved"/>
      </Action>

      <Action Name="Reject" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Remediation"/>
        <Parameter Name="Reason" Type="Edm.String"/>
        <ReturnType Type="Temper.OnCall.Remediation"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Proposed</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Rejected"/>
      </Action>

      <Action Name="AutoApprove" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Remediation"/>
        <ReturnType Type="Temper.OnCall.Remediation"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Proposed</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Approved"/>
        <Annotation Term="Temper.Vocab.Agent.Hint"
                    String="Auto-approve safe remediation actions like pod restarts or scaling."/>
      </Action>

      <Action Name="Execute" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Remediation"/>
        <ReturnType Type="Temper.OnCall.Remediation"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Approved</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Executing"/>
      </Action>

      <Action Name="Succeed" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Remediation"/>
        <ReturnType Type="Temper.OnCall.Remediation"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Executing</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Succeeded"/>
      </Action>

      <Action Name="Fail" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Remediation"/>
        <Parameter Name="ErrorMessage" Type="Edm.String"/>
        <ReturnType Type="Temper.OnCall.Remediation"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Executing</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Failed"/>
      </Action>

      <Action Name="Retry" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Remediation"/>
        <ReturnType Type="Temper.OnCall.Remediation"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Failed</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Approved"/>
      </Action>

      <!-- Postmortem Actions -->
      <Action Name="AddRootCause" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Postmortem"/>
        <Parameter Name="RootCauseDescription" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Temper.OnCall.Postmortem"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Draft</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.Agent.Hint"
                    String="Add root cause analysis. Required before the postmortem can be submitted for review."/>
      </Action>

      <Action Name="SubmitForReview" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Postmortem"/>
        <ReturnType Type="Temper.OnCall.Postmortem"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Draft</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="InReview"/>
      </Action>

      <Action Name="RequestRevision" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Postmortem"/>
        <Parameter Name="Feedback" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Temper.OnCall.Postmortem"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>InReview</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Draft"/>
      </Action>

      <Action Name="ApprovePostmortem" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Postmortem"/>
        <ReturnType Type="Temper.OnCall.Postmortem"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>InReview</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Approved"/>
      </Action>

      <Action Name="Publish" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.OnCall.Postmortem"/>
        <ReturnType Type="Temper.OnCall.Postmortem"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates">
          <Collection><String>Approved</String></Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Published"/>
      </Action>

      <!-- ============ Entity Container ============ -->

      <EntityContainer Name="OnCallService">
        <EntitySet Name="Pages" EntityType="Temper.OnCall.Page">
          <NavigationPropertyBinding Path="Remediations" Target="Remediations"/>
          <NavigationPropertyBinding Path="Postmortem" Target="Postmortems"/>
        </EntitySet>
        <EntitySet Name="EscalationPolicies" EntityType="Temper.OnCall.EscalationPolicy"/>
        <EntitySet Name="Remediations" EntityType="Temper.OnCall.Remediation">
          <NavigationPropertyBinding Path="Page" Target="Pages"/>
        </EntitySet>
        <EntitySet Name="Postmortems" EntityType="Temper.OnCall.Postmortem">
          <NavigationPropertyBinding Path="Page" Target="Pages"/>
        </EntitySet>
      </EntityContainer>

    </Schema>
  </edmx:DataServices>
</edmx:Edmx>
