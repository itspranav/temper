<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
  <edmx:DataServices>
    <Schema Namespace="Temper" xmlns="http://docs.oasis-open.org/odata/ns/edm">

      <EntityType Name="Plan">
        <Key><PropertyRef Name="id"/></Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="description" Type="Edm.String"/>
        <Property Name="task_count" Type="Edm.String"/>
        <Property Name="last_task_id" Type="Edm.String"/>
        <Property Name="summary" Type="Edm.String"/>
        <Property Name="reason" Type="Edm.String"/>
        <NavigationProperty Name="Tasks" Type="Collection(Temper.Task)"/>
        <NavigationProperty Name="Agents" Type="Collection(Temper.Agent)"/>
      </EntityType>

      <EntityType Name="Task">
        <Key><PropertyRef Name="id"/></Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="plan_id" Type="Edm.String"/>
        <Property Name="agent_id" Type="Edm.String"/>
        <Property Name="title" Type="Edm.String"/>
        <Property Name="description" Type="Edm.String"/>
        <Property Name="deliverable" Type="Edm.String"/>
        <Property Name="feedback" Type="Edm.String"/>
        <Property Name="reason" Type="Edm.String"/>
        <NavigationProperty Name="Plan" Type="Temper.Plan">
          <ReferentialConstraint Property="plan_id" ReferencedProperty="id"/>
        </NavigationProperty>
        <NavigationProperty Name="Agent" Type="Temper.Agent" Nullable="true">
          <ReferentialConstraint Property="agent_id" ReferencedProperty="id"/>
        </NavigationProperty>
      </EntityType>

      <EntityType Name="AgentType">
        <Key><PropertyRef Name="id"/></Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="name" Type="Edm.String"/>
        <Property Name="system_prompt" Type="Edm.String"/>
        <Property Name="tool_set" Type="Edm.String"/>
        <Property Name="model" Type="Edm.String"/>
        <Property Name="max_turns" Type="Edm.String"/>
        <Property Name="adapter_config" Type="Edm.String"/>
        <Property Name="default_budget_cents" Type="Edm.String"/>
      </EntityType>

      <EntityType Name="Agent">
        <Key><PropertyRef Name="id"/></Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="role" Type="Edm.String"/>
        <Property Name="goal" Type="Edm.String"/>
        <Property Name="model" Type="Edm.String"/>
        <Property Name="task_id" Type="Edm.String"/>
        <Property Name="plan_id" Type="Edm.String"/>
        <Property Name="result" Type="Edm.String"/>
        <Property Name="block_reason" Type="Edm.String"/>
        <Property Name="conversation" Type="Edm.String"/>
        <Property Name="executor_id" Type="Edm.String"/>
        <Property Name="child_agent_ids" Type="Collection(Edm.String)"/>
        <Property Name="last_child_id" Type="Edm.String"/>
        <Property Name="agent_type_id" Type="Edm.String"/>
        <Property Name="org_id" Type="Edm.String"/>
        <Property Name="reports_to" Type="Edm.String"/>
        <Property Name="adapter_type" Type="Edm.String"/>
        <Property Name="budget_monthly_cents" Type="Edm.String"/>
        <Property Name="cost_consumed_cents" Type="Edm.String"/>
        <NavigationProperty Name="Task" Type="Temper.Task" Nullable="true">
          <ReferentialConstraint Property="task_id" ReferencedProperty="id"/>
        </NavigationProperty>
        <NavigationProperty Name="Plan" Type="Temper.Plan" Nullable="true">
          <ReferentialConstraint Property="plan_id" ReferencedProperty="id"/>
        </NavigationProperty>
        <NavigationProperty Name="AgentType" Type="Temper.AgentType" Nullable="true">
          <ReferentialConstraint Property="agent_type_id" ReferencedProperty="id"/>
        </NavigationProperty>
      </EntityType>

      <EntityType Name="ToolCall">
        <Key><PropertyRef Name="id"/></Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="agent_id" Type="Edm.String"/>
        <Property Name="tool_name" Type="Edm.String"/>
        <Property Name="tool_input" Type="Edm.String"/>
        <Property Name="resource_type" Type="Edm.String"/>
        <Property Name="resource_id" Type="Edm.String"/>
        <Property Name="result" Type="Edm.String"/>
        <Property Name="error" Type="Edm.String"/>
        <Property Name="decision_id" Type="Edm.String"/>
        <Property Name="duration_ms" Type="Edm.String"/>
        <NavigationProperty Name="Agent" Type="Temper.Agent">
          <ReferentialConstraint Property="agent_id" ReferencedProperty="id"/>
        </NavigationProperty>
      </EntityType>

      <EntityType Name="Schedule">
        <Key><PropertyRef Name="id"/></Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="agent_type_id" Type="Edm.String"/>
        <Property Name="agent_role" Type="Edm.String"/>
        <Property Name="goal_template" Type="Edm.String"/>
        <Property Name="cron_expr" Type="Edm.String"/>
        <Property Name="last_run" Type="Edm.String"/>
        <Property Name="run_count" Type="Edm.String"/>
        <Property Name="max_runs" Type="Edm.String"/>
        <NavigationProperty Name="AgentType" Type="Temper.AgentType" Nullable="true">
          <ReferentialConstraint Property="agent_type_id" ReferencedProperty="id"/>
        </NavigationProperty>
      </EntityType>

      <EntityType Name="AgentCredential">
        <Key><PropertyRef Name="id"/></Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="agent_type_id" Type="Edm.String"/>
        <Property Name="agent_instance_id" Type="Edm.String"/>
        <Property Name="key_hash" Type="Edm.String"/>
        <Property Name="key_prefix" Type="Edm.String"/>
        <Property Name="description" Type="Edm.String"/>
        <Property Name="created_by" Type="Edm.String"/>
        <Property Name="expires_at" Type="Edm.String"/>
        <NavigationProperty Name="AgentType" Type="Temper.AgentType" Nullable="true">
          <ReferentialConstraint Property="agent_type_id" ReferencedProperty="id"/>
        </NavigationProperty>
      </EntityType>

      <EntityType Name="Policy">
        <Key><PropertyRef Name="id"/></Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="name" Type="Edm.String"/>
        <Property Name="description" Type="Edm.String"/>
        <Property Name="cedar_statement" Type="Edm.String"/>
        <Property Name="proposed_by" Type="Edm.String"/>
        <Property Name="reason" Type="Edm.String"/>
      </EntityType>

      <Action Name="Issue" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.AgentCredential"/>
        <Parameter Name="agent_type_id" Type="Edm.String" Nullable="false"/>
        <Parameter Name="agent_instance_id" Type="Edm.String" Nullable="false"/>
        <Parameter Name="key_hash" Type="Edm.String" Nullable="false"/>
        <Parameter Name="key_prefix" Type="Edm.String" Nullable="false"/>
        <Parameter Name="description" Type="Edm.String" Nullable="true"/>
        <Parameter Name="created_by" Type="Edm.String" Nullable="true"/>
        <Parameter Name="expires_at" Type="Edm.String" Nullable="true"/>
        <ReturnType Type="Temper.AgentCredential"/>
      </Action>

      <Action Name="Rotate" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.AgentCredential"/>
        <Parameter Name="key_hash" Type="Edm.String" Nullable="false"/>
        <Parameter Name="key_prefix" Type="Edm.String" Nullable="false"/>
        <Parameter Name="description" Type="Edm.String" Nullable="true"/>
        <ReturnType Type="Temper.AgentCredential"/>
      </Action>

      <Action Name="Revoke" IsBound="true">
        <Parameter Name="bindingParameter" Type="Temper.AgentCredential"/>
        <ReturnType Type="Temper.AgentCredential"/>
      </Action>

      <EntityContainer Name="Service">
        <EntitySet Name="AgentTypes" EntityType="Temper.AgentType"/>
        <EntitySet Name="Schedules" EntityType="Temper.Schedule">
          <NavigationPropertyBinding Path="AgentType" Target="AgentTypes"/>
        </EntitySet>
        <EntitySet Name="Plans" EntityType="Temper.Plan">
          <NavigationPropertyBinding Path="Tasks" Target="Tasks"/>
          <NavigationPropertyBinding Path="Agents" Target="Agents"/>
        </EntitySet>
        <EntitySet Name="Tasks" EntityType="Temper.Task">
          <NavigationPropertyBinding Path="Plan" Target="Plans"/>
          <NavigationPropertyBinding Path="Agent" Target="Agents"/>
        </EntitySet>
        <EntitySet Name="Agents" EntityType="Temper.Agent">
          <NavigationPropertyBinding Path="Task" Target="Tasks"/>
          <NavigationPropertyBinding Path="Plan" Target="Plans"/>
          <NavigationPropertyBinding Path="AgentType" Target="AgentTypes"/>
        </EntitySet>
        <EntitySet Name="ToolCalls" EntityType="Temper.ToolCall">
          <NavigationPropertyBinding Path="Agent" Target="Agents"/>
        </EntitySet>
        <EntitySet Name="Policies" EntityType="Temper.Policy"/>
        <EntitySet Name="AgentCredentials" EntityType="Temper.AgentCredential">
          <NavigationPropertyBinding Path="AgentType" Target="AgentTypes"/>
        </EntitySet>
      </EntityContainer>

    </Schema>
  </edmx:DataServices>
</edmx:Edmx>
